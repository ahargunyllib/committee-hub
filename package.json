{
  "name": "committee-hub",
  "scripts": {
    "build:api": "bun --cwd apps/api build",
    "build:dashboard": "bun --cwd apps/dashboard build",
    "cf-typegen:api": "bun --cwd apps/api cf-typegen",
    "check": "ultracite check",
    "deploy:api": "bun --cwd apps/api deploy",
    "deploy:dashboard": "bun --cwd apps/dashboard deploy",
    "dev": "bun --filter \"*\" dev",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "typecheck": "bun --filter \"*\" typecheck",
    "test": "bun --filter \"*\" test"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "better-auth": "^1.6.11",
      "typescript": "^5.9.3"
    }
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.8",
    "typescript": "catalog:",
    "ultracite": "7.7.0",
    "wrangler": "^4.94.0"
  }
}
